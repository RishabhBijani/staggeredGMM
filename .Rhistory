w_EW[ci] <- (1 / K) / T_g_count[g_c]
w_CW[ci] <- N_g_lookup[g_c] / N_total_post
}
w_EW <- w_EW / sum(w_EW)
w_CW <- w_CW / sum(w_CW)
eff_ok           <- FALSE
Omega_phi_out    <- NULL
cohort_cov_out <- NULL
QtAQ_out         <- NULL
n_iter           <- 0L
# Fixed incidence factor of Omega_phi = U W U' (U is data-independent: it
# depends only on the design). Its SVD basis and the projections u'Q_H, u'Delta
# are precomputed ONCE; each GMM iteration then works only in the
# m = n_grp*TT dimensional space, never forming an N_2x2-sized object.
m_cols <- n_grp * TT
U_fac  <- matrix(0.0, nrow = N_2x2, ncol = m_cols)
for (gi in seq_len(n_grp)) {
active <- active_by_grp[[gi]]
if (length(active) == 0L) next
sgn  <- sign_by_grp[[gi]]
cols <- ((gi - 1L) * TT + 1L):(gi * TT)
tp_i <- meta_tp[active] - T_min + 1L
tr_i <- meta_tr[active] - T_min + 1L
U_fac[cbind(active, cols[tp_i])] <- U_fac[cbind(active, cols[tp_i])] + sgn
U_fac[cbind(active, cols[tr_i])] <- U_fac[cbind(active, cols[tr_i])] - sgn
}
red_fac <- gmm_reduced_factor(U_fac, Q_H, Delta)
for (iter in seq_len(max_iter)) {
n_iter   <- iter
beta_old <- beta_hat
idx <- match(paste(dt_long$g, dt_long$time),
paste(cells$g,   cells$t))
dt_long[, tau_hat := ifelse(is.na(idx), 0, beta_hat[idx])]
dt_long[, Y_adj   := Y - tau_hat]
fe_mod <- feols(Y_adj ~ 1 | unit + time, data = dt_long)
R_mat  <- matrix(NA_real_, nrow = N_units, ncol = TT)
R_mat[cbind(dt_long$unit_row, dt_long$time_idx)] <- residuals(fe_mod)
# Block-diagonal W (changes with beta through the residuals). Each cohort
# uses an UNRESTRICTED within-unit covariance (full T x T): arbitrary serial
# correlation is allowed, cross-sectional dependence is ignored.
W               <- matrix(0.0, nrow = m_cols, ncol = m_cols)
cohort_cov_list <- vector("list", n_grp)   # full T x T cohort covariance
for (gi in seq_len(n_grp)) {
g_val   <- all_cohorts[gi]
N_g     <- N_g_lookup[as.character(g_val)]
units_g <- units_by_grp[[gi]]
active  <- active_by_grp[[gi]]
cols    <- ((gi - 1L) * TT + 1L):(gi * TT)
if (length(active) == 0L || length(units_g) == 0L) {
cohort_cov_list[[gi]] <- matrix(NA_real_, TT, TT)
next
}
rm_g  <- R_mat[units_g, , drop = FALSE]          # N_g x TT
Sig_g <- crossprod(rm_g) / N_g                   # TT x TT unrestricted cov
cohort_cov_list[[gi]] <- Sig_g
W[cols, cols] <- Sig_g / N_g
}
cohort_cov_out <- cohort_cov_list
# Optimal-GMM normal equations via the generalized inverse, in reduced space.
red <- gmm_reduced_solve(red_fac, W, tol_rel = eig_tol)
if (is.null(red)) break
QtAQ     <- red$QtAQ
QtAD     <- red$QtAD
beta_new <- tryCatch(solve(QtAQ, QtAD), error = function(e) NULL)
if (is.null(beta_new)) break
QtAQ_out <- QtAQ
eff_ok   <- TRUE
beta_hat <- beta_new
if (max(abs(beta_hat - beta_old)) < tol) break
}
if (eff_ok) {
V_beta <- tryCatch(
solve(QtAQ_out),
error = function(e) ginv(as.matrix(QtAQ_out))
)
} else {
V_beta <- ginv(crossprod(Q_H))   # degenerate fallback (not reached in practice)
}
SE_catt <- sqrt(pmax(0, diag(V_beta)))
ATT_EW  <- as.numeric(crossprod(w_EW, beta_hat))
ATT_CW  <- as.numeric(crossprod(w_CW, beta_hat))
SE_EW   <- sqrt(max(0, as.numeric(crossprod(w_EW, V_beta %*% w_EW))))
SE_CW   <- sqrt(max(0, as.numeric(crossprod(w_CW, V_beta %*% w_CW))))
names(cohort_cov_out) <- as.character(all_cohorts)
list(
beta_hat    = beta_hat,
SE_catt     = SE_catt,
catt_out    = data.frame(g = cells$g, t = cells$t,
beta_hat = beta_hat, SE = SE_catt),
ATT_EW      = ATT_EW,
ATT_CW      = ATT_CW,
SE_EW       = SE_EW,
SE_CW       = SE_CW,
w_EW        = w_EW,
w_CW        = w_CW,
cells       = cells,
eff_ok      = eff_ok,
n_iter      = n_iter,
N_beta      = N_beta,
N_2x2       = N_2x2,
Q_H_rank    = Q_H_rank,
cohort_cov  = cohort_cov_out
)
}
# -----------------------------------------------------------------------
# SECTION 3: GLS-I / GLS-II / GLS-III (verbatim from script_1)
# -----------------------------------------------------------------------
.chol_pd <- function(S) {
S  <- (S + t(S)) / 2
ok <- tryCatch({ chol(S); TRUE }, error = function(e) FALSE)
if (!ok) {
ev <- min(eigen(S, symmetric = TRUE, only.values = TRUE)$values)
diag(S) <- diag(S) + max(0, -ev) + 1e-8
} else {
diag(S) <- diag(S) + 1e-8
}
chol(S)
}
build_flex_design <- function(dt) {
dd <- copy(dt)
setorder(dd, unit, time)
dd[, treat_gt := fifelse(D == 1L, g * 100L + as.integer(time), 0L)]
dd[, unit_f := factor(unit)]
dd[, time_f := factor(time)]
dd[, tg_f   := relevel(factor(treat_gt), ref = "0")]
Z  <- model.matrix(~ unit_f + time_f + tg_f, data = dd)
cn <- colnames(Z)
tg_cols <- grep("^tg_f", cn)
tg_keys <- as.integer(sub("^tg_f", "", cn[tg_cols]))
catt_g  <- tg_keys %/% 100L
catt_t  <- tg_keys %%  100L
N_units <- length(unique(dd$unit))
TT      <- length(unique(dd$time))
row_cohort       <- as.integer(dd$g)
unit_cohort_sort <- row_cohort[seq(1L, nrow(dd), by = TT)]  # cohort per unit (R_mat row order)
groups           <- sort(unique(row_cohort))
rows_by_grp      <- lapply(groups, function(g) which(row_cohort == g))
units_by_grp     <- lapply(groups, function(g) which(unit_cohort_sort == g))
Ng_by_grp        <- vapply(units_by_grp, length, integer(1L))
# aggregation weights over CATT cells (match GMM EW / CW conventions)
start_yrs        <- sort(unique(catt_g))
K                <- length(start_yrs)
T_g_count        <- vapply(start_yrs, function(g) sum(catt_g == g), integer(1L))
names(T_g_count) <- as.character(start_yrs)
Ng_treated       <- setNames(
vapply(start_yrs, function(g) Ng_by_grp[match(g, groups)], integer(1L)),
as.character(start_yrs))
N_total_post     <- sum(Ng_treated[as.character(start_yrs)] *
T_g_count[as.character(start_yrs)])
w_EW <- numeric(length(tg_cols)); w_CW <- numeric(length(tg_cols))
for (j in seq_along(tg_cols)) {
gc      <- as.character(catt_g[j])
w_EW[j] <- (1 / K) / T_g_count[gc]
w_CW[j] <- Ng_treated[gc] / N_total_post
}
w_EW <- w_EW / sum(w_EW)
w_CW <- w_CW / sum(w_CW)
XtX     <- crossprod(Z)
XtX_inv <- tryCatch(solve(XtX), error = function(e) ginv(XtX))
list(Z = Z, tg_cols = tg_cols, catt_g = catt_g, catt_t = catt_t,
N_units = N_units, TT = TT, groups = groups,
rows_by_grp = rows_by_grp, units_by_grp = units_by_grp,
Ng_by_grp = Ng_by_grp, w_EW = w_EW, w_CW = w_CW,
XtX_inv = XtX_inv)
}
flex_gls_fit <- function(design, Yvec,
cov_type = c("toeplitz_homo", "toeplitz_hetero", "full_hetero"),
max_iter = 10L, tol = 1e-6) {
cov_type <- match.arg(cov_type)
Z   <- design$Z
TT  <- design$TT
Nu  <- design$N_units
grp <- design$groups
beta <- as.numeric(design$XtX_inv %*% crossprod(Z, Yvec))   # initial OLS
iter <- 0L
for (iter in seq_len(max_iter)) {
beta_old <- beta
r        <- as.numeric(Yvec - Z %*% beta)
R_mat    <- matrix(r, nrow = Nu, ncol = TT, byrow = TRUE)  # unit x time
sigma_d_pool <- NULL
if (cov_type == "toeplitz_homo") {
sigma_d_pool <- numeric(TT)
for (d in 0L:(TT - 1L))
sigma_d_pool[d + 1L] <- sum(R_mat[, seq_len(TT - d)] *
R_mat[, (1L + d):TT]) / (Nu * (TT - d))
}
Yt <- numeric(length(Yvec))
Zt <- matrix(0.0, nrow = nrow(Z), ncol = ncol(Z))
for (gi in seq_along(grp)) {
rows_g  <- design$rows_by_grp[[gi]]
units_g <- design$units_by_grp[[gi]]
N_g     <- design$Ng_by_grp[gi]
if (length(rows_g) == 0L) next
if (cov_type == "toeplitz_homo") {
Sig_g <- toeplitz(sigma_d_pool)
} else if (cov_type == "toeplitz_hetero") {
Rg <- R_mat[units_g, , drop = FALSE]
sd <- numeric(TT)
for (d in 0L:(TT - 1L))
sd[d + 1L] <- sum(Rg[, seq_len(TT - d)] * Rg[, (1L + d):TT]) /
(N_g * (TT - d))
Sig_g <- toeplitz(sd)
} else {                                   # full_hetero
Rg    <- R_mat[units_g, , drop = FALSE]
Sig_g <- crossprod(Rg) / N_g             # T x T unrestricted
}
U   <- .chol_pd(Sig_g)
P_g <- solve(t(U))                         # P_g' P_g = Sigma_g^{-1}
## transform outcome for this cohort group
Ymat       <- matrix(Yvec[rows_g], nrow = TT)           # T x N_g
Yt[rows_g] <- as.numeric(P_g %*% Ymat)
## transform design (block-diagonal: same P_g per unit)
A            <- matrix(Z[rows_g, ], nrow = TT)          # T x (N_g * p)
Zt[rows_g, ] <- matrix(P_g %*% A, nrow = length(rows_g))
}
XtX  <- crossprod(Zt)
XtY  <- crossprod(Zt, Yt)
beta <- tryCatch(as.numeric(solve(XtX, XtY)),
error = function(e) as.numeric(ginv(XtX) %*% XtY))
if (max(abs(beta - beta_old)) < tol) break
}
catt   <- beta[design$tg_cols]
ATT_EW <- sum(design$w_EW * catt)
ATT_CW <- sum(design$w_CW * catt)
# Var(beta) = (Zt'Zt)^{-1} at the converged GLS weighting (Zt is already
# Sigma^{-1/2}-whitened, so this is the standard GLS variance with no
# further weighting needed). Same tryCatch(solve, ginv) fallback used
# throughout the GMM code for rank-deficient cases.
V_beta <- tryCatch(solve(XtX), error = function(e) ginv(as.matrix(XtX)))
V_catt <- V_beta[design$tg_cols, design$tg_cols, drop = FALSE]
SE_EW  <- sqrt(max(0, as.numeric(crossprod(design$w_EW, V_catt %*% design$w_EW))))
SE_CW  <- sqrt(max(0, as.numeric(crossprod(design$w_CW, V_catt %*% design$w_CW))))
list(ATT_EW = ATT_EW, ATT_CW = ATT_CW, SE_EW = SE_EW, SE_CW = SE_CW,
catt = catt, n_iter = iter)
}
# -----------------------------------------------------------------------
# SECTION 4: TWFE / CS / SA / Gardner / Flex-TWFE
# Point estimates are script_1's exact calls (feols/att_gt/sunab/did2s),
# unchanged. Each now also returns se: for TWFE/CS/SA/Gardner this is
# simply se()/the package's own second coeftable column/overall.se --
# values those calls already compute internally, just no longer
# discarded. Flex-TWFE's se is the standard delta-method SE of the same
# unweighted mean-of-coefficients point estimate already being reported,
# sqrt(w'Vw) with V = vcov(mod) -- the identical formula used for
# SE_CW/SE_EW throughout the GMM code, applied here to feols's own vcov.
# No new estimation methodology; each function returns list(att, se).
# -----------------------------------------------------------------------
estimate_twfe <- function(dt) {
tryCatch({
mod <- feols(Y ~ D | unit + time, data = dt)
list(att = as.numeric(coef(mod)["D"]), se = as.numeric(se(mod)["D"]))
}, error = function(e) list(att = NA_real_, se = NA_real_))
}
estimate_cs <- function(dt) {
tryCatch({
out <- att_gt(yname = "Y", tname = "time", idname = "unit", gname = "g_cs",
data = as.data.frame(dt), control_group = "nevertreated",
print_details = FALSE, bstrap = FALSE, cband = FALSE)
agg <- aggte(out, type = "simple")
list(att = as.numeric(agg$overall.att), se = as.numeric(agg$overall.se))
}, error = function(e) list(att = NA_real_, se = NA_real_))
}
estimate_sa <- function(dt) {
tryCatch({
mod <- feols(Y ~ sunab(g_inf, time) | unit + time, data = dt)
ct  <- summary(mod, agg = "ATT")$coeftable
list(att = as.numeric(ct[1, 1]), se = as.numeric(ct[1, 2]))
}, error = function(e) list(att = NA_real_, se = NA_real_))
}
estimate_gardner <- function(dt) {
tryCatch({
dt_g <- copy(dt)
dt_g[, first_treat := fifelse(g == 0, Inf, as.numeric(g))]
mod <- did2s(data = as.data.frame(dt_g), yname = "Y",
first_stage = ~ 0 | unit + time, second_stage = ~ i(D, ref = 0),
treatment = "D", cluster_var = "unit", verbose = FALSE)
list(att = as.numeric(coef(mod)["D::1"]), se = as.numeric(se(mod)["D::1"]))
}, error = function(e) list(att = NA_real_, se = NA_real_))
}
estimate_flex_twfe <- function(dt) {
tryCatch({
dt_f <- copy(dt)
dt_f[, treat_gt := fifelse(D == 1, g * 100L + as.integer(time), 0L)]
mod <- feols(Y ~ i(treat_gt, ref = 0) | unit + time, data = dt_f)
cf  <- coef(mod)
V   <- vcov(mod)
w   <- rep(1 / length(cf), length(cf))
att <- as.numeric(mean(cf, na.rm = TRUE))
se  <- sqrt(max(0, as.numeric(crossprod(w, V %*% w))))
list(att = att, se = se)
}, error = function(e) list(att = NA_real_, se = NA_real_))
}
# -----------------------------------------------------------------------
# SECTION 5: runner -- takes a standardized panel and runs all 11
# estimators, printing GMM identification diagnostics (Q_H rank, eff_ok,
# n_iter) so identification gaps are never silently hidden.
#
#   dt      : data.table(unit, time, Y, D, g, g_cs, g_inf). Used for TWFE,
#             CS, SA, Gardner, and all three GMM variants.
#   gls_dt  : same columns, used for Flex-TWFE and GLS-I/II/III. Defaults
#             to dt. Pass a restricted version when dt contains units for
#             which g == 0 but D == 1 in some periods (e.g. Beck Panel A's
#             always-treated states) -- build_flex_design()'s treat_gt =
#             g*100+time encoding assumes g==0 implies D==0 for every
#             period, and breaks (spurious per-period dummies) when that's
#             violated. See the accompanying message for detail.
#   has_nt  : must match whether a genuine never-treated group (g==0,
#             D==0 always) exists in dt.
# -----------------------------------------------------------------------
run_all_estimators <- function(dt, gls_dt = dt, has_nt, label) {
cat(sprintf("\n%s\n=== %s ===\n%s\n", strrep("=", 60), label, strrep("=", 60)))
cat(sprintf("N units (main sample): %d | N units (GLS/Flex-TWFE sample): %d | has_nt = %s\n",
uniqueN(dt$unit), uniqueN(gls_dt$unit), has_nt))
if (all(dt$g_cs != 0)) {
cat("  [CS note] no g_cs = 0 units present; att_gt(control_group = 'nevertreated')\n",
"  will use its documented fallback (drops the last period, uses units not yet\n",
"  treated by the last period as control -- see the 'did' package vignette).\n", sep = "")
}
att_twfe    <- estimate_twfe(dt)
att_cs      <- estimate_cs(dt)
att_sa      <- estimate_sa(dt)
att_gardner <- estimate_gardner(dt)
att_flex    <- estimate_flex_twfe(gls_dt)
cat(sprintf("  TWFE     : ATT=%.5f SE=%.5f\n", att_twfe$att, att_twfe$se))
cat(sprintf("  CS       : ATT=%.5f SE=%.5f\n", att_cs$att, att_cs$se))
cat(sprintf("  SA       : ATT=%.5f SE=%.5f\n", att_sa$att, att_sa$se))
cat(sprintf("  Gardner  : ATT=%.5f SE=%.5f\n", att_gardner$att, att_gardner$se))
cat(sprintf("  Flex-TWFE: ATT=%.5f SE=%.5f\n", att_flex$att, att_flex$se))
cat("-- GMM (V2, reduced-space) --\n")
g1 <- tryCatch(gmm_staggered_toeplitz_rd(dt, "Y", "time", "unit", "g",
variance = "homo", has_nt = has_nt),
error = function(e) { cat("  GMM-I failed:", conditionMessage(e), "\n"); NULL })
if (!is.null(g1)) cat(sprintf("  GMM-I  : ATT_CW=%.5f SE_CW=%.5f | Q_H rank=%d/%d | eff_ok=%s n_iter=%d\n",
g1$ATT_CW, g1$SE_CW, g1$Q_H_rank, g1$N_beta, g1$eff_ok, g1$n_iter))
g2 <- tryCatch(gmm_staggered_toeplitz_rd(dt, "Y", "time", "unit", "g",
variance = "hetero", has_nt = has_nt),
error = function(e) { cat("  GMM-II failed:", conditionMessage(e), "\n"); NULL })
if (!is.null(g2)) cat(sprintf("  GMM-II : ATT_CW=%.5f SE_CW=%.5f | Q_H rank=%d/%d | eff_ok=%s n_iter=%d\n",
g2$ATT_CW, g2$SE_CW, g2$Q_H_rank, g2$N_beta, g2$eff_ok, g2$n_iter))
g3 <- tryCatch(gmm_staggered_fullcov_rd(dt, "Y", "time", "unit", "g", has_nt = has_nt),
error = function(e) { cat("  GMM-III failed:", conditionMessage(e), "\n"); NULL })
if (!is.null(g3)) cat(sprintf("  GMM-III: ATT_CW=%.5f SE_CW=%.5f | Q_H rank=%d/%d | eff_ok=%s n_iter=%d\n",
g3$ATT_CW, g3$SE_CW, g3$Q_H_rank, g3$N_beta, g3$eff_ok, g3$n_iter))
cat("-- GLS --\n")
design <- tryCatch(build_flex_design(gls_dt),
error = function(e) { cat("  build_flex_design failed:", conditionMessage(e), "\n"); NULL })
gls_res <- setNames(vector("list", 3L), c("toeplitz_homo", "toeplitz_hetero", "full_hetero"))
if (!is.null(design)) {
for (ct in names(gls_res)) {
gls_res[[ct]] <- tryCatch(flex_gls_fit(design, gls_dt$Y, ct),
error = function(e) { cat(sprintf("  GLS[%s] failed: %s\n", ct, conditionMessage(e))); NULL })
if (!is.null(gls_res[[ct]]))
cat(sprintf("  GLS[%s]: ATT_CW=%.5f SE_CW=%.5f n_iter=%d\n",
ct, gls_res[[ct]]$ATT_CW, gls_res[[ct]]$SE_CW, gls_res[[ct]]$n_iter))
}
}
data.table(
Application = label,
Estimator   = c("TWFE", "CS", "SA", "Gardner", "Flex_TWFE",
"GMM_I", "GMM_II", "GMM_III", "GLS_I", "GLS_II", "GLS_III"),
ATT = c(att_twfe$att, att_cs$att, att_sa$att, att_gardner$att, att_flex$att,
if (!is.null(g1)) g1$ATT_CW else NA_real_,
if (!is.null(g2)) g2$ATT_CW else NA_real_,
if (!is.null(g3)) g3$ATT_CW else NA_real_,
if (!is.null(gls_res$toeplitz_homo))   gls_res$toeplitz_homo$ATT_CW   else NA_real_,
if (!is.null(gls_res$toeplitz_hetero)) gls_res$toeplitz_hetero$ATT_CW else NA_real_,
if (!is.null(gls_res$full_hetero))     gls_res$full_hetero$ATT_CW     else NA_real_),
SE = c(att_twfe$se, att_cs$se, att_sa$se, att_gardner$se, att_flex$se,
if (!is.null(g1)) g1$SE_CW else NA_real_,
if (!is.null(g2)) g2$SE_CW else NA_real_,
if (!is.null(g3)) g3$SE_CW else NA_real_,
if (!is.null(gls_res$toeplitz_homo))   gls_res$toeplitz_homo$SE_CW   else NA_real_,
if (!is.null(gls_res$toeplitz_hetero)) gls_res$toeplitz_hetero$SE_CW else NA_real_,
if (!is.null(gls_res$full_hetero))     gls_res$full_hetero$SE_CW     else NA_real_)
)
}
# -----------------------------------------------------------------------
# SECTION 6: application-specific data prep (new glue -- no estimator
# logic here, only construction of the standardized unit/time/Y/D/g panel
# each function above expects). Time and cohort are reindexed to abstract
# 1..TT integers because build_flex_design()/estimate_flex_twfe()'s
# treat_gt = g*100+time encoding requires small integers to stay unique;
# the GMM functions re-derive their own T_min/T_max internally either way.
# -----------------------------------------------------------------------
## 6a. Beck et al. (2010) -- Panel A (49 states) / Panel B (37 states)
prep_beck <- function(path, panel = c("A", "B")) {
panel <- match.arg(panel)
df <- as.data.table(read_csv(path, show_col_types = FALSE))
T_min <- min(df$wrkyr); T_max <- max(df$wrkyr)
# Panel B: always-treated states (deregulated before the sample window)
# dropped outright -- this is the entire distinction between the panels.
if (panel == "B") df <- df[branch_reform >= T_min]
g_raw <- as.integer(df$branch_reform)
g_idx <- ifelse(g_raw >= T_min & g_raw <= T_max, g_raw - T_min + 1L, 0L)
dt <- data.table(
unit = df$statefip,
time = as.integer(df$wrkyr) - T_min + 1L,
Y    = df$ln_gini,
D    = as.integer(df$D_branch),   # real treatment indicator, trusted as-is --
# NOT re-derived from g_idx (see note below)
g    = g_idx
)
dt[, g_inf := fifelse(g == 0, Inf, as.numeric(g))]
dt[, g_cs  := fifelse(g == 0, 0,   as.numeric(g))]
# Panel A only: the 12 always-treated states get g = 0, same sentinel as
# a genuine never-treated unit (there are none in this data). GMM/GLS's
# own "cohort_of > 0" filter already excludes g=0 from every moment, so
# no extra step is needed there -- matches the old script's "no focal,
# no control" convention, and D is left at its true value (1 throughout)
# so those states still inform the two-way demeaning / FE step.
# For CS/SA/Gardner, g_cs=0 / g_inf=Inf makes them act as pseudo-never-
# treated controls -- the old reference script's convention, not
# something in script_1 itself (script_1's own simulation never has an
# always-treated case). This is the one place Panel A carries more
# information than Panel B for these three estimators specifically.
# For Flex-TWFE/GLS, g==0 combined with D==1 breaks the treat_gt
# encoding (spurious per-period dummies) -- gls_dt drops these states
# for those two estimators only. Confirmed empirically before writing
# this in: see the message accompanying this script.
gls_dt <- dt[g > 0]
list(dt = dt, gls_dt = gls_dt, has_nt = FALSE,
label = sprintf("Beck et al. (2010) -- Panel %s", panel))
}
## 6b. Cook & Shah (2023) NREGS -- FE1 (district + time) only
prep_cook_shah <- function(path) {
df <- as.data.table(as.data.frame(read_dta(path)))
first_row  <- df[, .SD[1L], by = sno]
cohort_raw <- with(first_row, ifelse(nr06 == 1, 2006L,
ifelse(nr07 == 1, 2007L,
ifelse(nr08 == 1, 2008L, NA_integer_))))
n_na <- sum(is.na(cohort_raw))
if (n_na > 0L)
warning(sprintf(
paste("Cook-Shah: %d of %d districts have none of nr06/nr07/nr08 set;",
"dropping as a data gap. NREGS reached universal coverage by 2008,",
"so this should NOT be a never-treated group -- confirm this is",
"really a data gap before trusting the estimates."),
n_na, length(cohort_raw)))
cohort_map <- setNames(cohort_raw, first_row$sno)
df <- df[!is.na(cohort_map[as.character(sno)])]
T_min <- min(df$year)
g_raw <- as.integer(cohort_map[as.character(df$sno)])
dt <- data.table(
unit = df$sno,
time = as.integer(df$year) - T_min + 1L,
Y    = df$std_lt,
g    = g_raw - T_min + 1L    # every district treated within window -- no sentinel
)
dt[, D := as.integer(g > 0 & time >= g)]
dt[, g_inf := fifelse(g == 0, Inf, as.numeric(g))]
dt[, g_cs  := fifelse(g == 0, 0,   as.numeric(g))]
list(dt = dt, gls_dt = dt, has_nt = FALSE,
label = "Cook & Shah (2023) NREGS -- FE1 (district + time)")
}
## 6c. Cheng & Hoekstra (2013) Castle Doctrine -- did2s::castle (canonical, 550 rows,
## columns year/state/popwt/l_homicide/post/effyear/time_til). No weights (popwt unused
## by design, per instruction -- not a survey/population-weighted specification here).
##
## Two things this fixes relative to deriving D from effyear directly:
## (1) The adoption year itself is still pre-treatment in this data (time_til = 0 has
##     post = 0; treatment starts at time_til = 1, i.e. effyear + 1). D now comes
##     straight from the data's own `post` column instead of a time >= effyear rule
##     that would misclassify every state's adoption year as post.
## (2) g is set to effyear + 1 (not effyear) so GMM/GLS's cohort machinery, which
##     infers treatment timing from g alone via time >= g, agrees with D everywhere --
##     confirmed consistent against the printed post/time_til values for effyear=2006.
prep_castle <- function() {
df <- as.data.table(did2s::castle)
first_row  <- df[, .SD[1L], by = state]
cohort_raw <- as.integer(first_row$effyear) + 1L   # treatment begins the year after effyear
cohort_raw[is.na(first_row$effyear)] <- 0L          # genuine never-treated
cohort_map <- setNames(cohort_raw, first_row$state)
T_min <- min(df$year)
g_raw <- as.integer(cohort_map[as.character(df$state)])
dt <- data.table(
unit = df$state,
time = as.integer(df$year) - T_min + 1L,
Y    = df$l_homicide,
D    = as.integer(df$post),   # data's own treatment indicator, used as-is
g    = ifelse(g_raw > 0L, g_raw - T_min + 1L, 0L)
)
dt[, g_inf := fifelse(g == 0, Inf, as.numeric(g))]
dt[, g_cs  := fifelse(g == 0, 0,   as.numeric(g))]
list(dt = dt, gls_dt = dt, has_nt = TRUE,
label = "Cheng & Hoekstra (2013) Castle Doctrine")
}
# -----------------------------------------------------------------------
# SECTION 7: run everything
# Update data_dir / out_dir and the file names below before running.
# -----------------------------------------------------------------------
data_dir <- "/Users/rishabhbijani/Desktop/Staggered_DiD"
out_dir  <- "/Users/rishabhbijani/Desktop/Staggered_DiD"
beck_A    <- prep_beck(file.path(data_dir, "panel_A_beck_replication.csv"), panel = "A")
beck_B    <- prep_beck(file.path(data_dir, "panel_B_modern_did_eligible.csv"), panel = "B")
cook_shah <- prep_cook_shah(file.path(data_dir, "district_light_panel.dta"))
castle    <- prep_castle()   # sources did2s::castle directly, no file needed
results <- rbindlist(list(
run_all_estimators(beck_A$dt,    beck_A$gls_dt,    beck_A$has_nt,    beck_A$label),
run_all_estimators(beck_B$dt,    beck_B$gls_dt,    beck_B$has_nt,    beck_B$label),
run_all_estimators(cook_shah$dt, cook_shah$gls_dt, cook_shah$has_nt, cook_shah$label),
run_all_estimators(castle$dt,    castle$gls_dt,    castle$has_nt,    castle$label)
))
