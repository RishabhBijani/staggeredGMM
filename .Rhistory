# Untreated". Checked against synthetic panels shaped like each case.
#
# NOT verified end-to-end: I don't have your Beck/Cook-Shah files, so I
# can't reproduce Table 6's exact numbers here beyond the Castle check
# above. The printed console summary is your check against that table --
# see the note by Beck Panel B (37 states per applications.R's comment vs.
# 36 in the draft's Table 6/7).
library(data.table)
library(fixest)
library(bacondecomp)
library(ggplot2)
library(readr)
library(haven)
options(warn = 1)
data_dir <- "/Users/rishabhbijani/Desktop/Staggered_DiD"
out_dir  <- file.path(data_dir, "bacon_plots")
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)
# -----------------------------------------------------------------------
# data prep -- (unit, time, Y, D) only, actual calendar time throughout
# -----------------------------------------------------------------------
prep_beck_bacon <- function(path, panel = c("A", "B")) {
panel <- match.arg(panel)
df <- as.data.table(read_csv(path, show_col_types = FALSE))
T_min <- min(df$wrkyr)
if (panel == "B") df <- df[branch_reform >= T_min]
data.table(unit = df$statefip, time = as.integer(df$wrkyr),
Y = df$ln_gini, D = as.integer(df$D_branch))
}
prep_cook_shah_bacon <- function(path) {
df <- as.data.table(as.data.frame(read_dta(path)))
first_row  <- df[, .SD[1L], by = sno]
cohort_raw <- with(first_row, ifelse(nr06 == 1, 2006L,
ifelse(nr07 == 1, 2007L,
ifelse(nr08 == 1, 2008L, NA_integer_))))
n_na <- sum(is.na(cohort_raw))
if (n_na > 0L)
warning(sprintf(
paste("Cook-Shah: %d of %d districts have none of nr06/nr07/nr08 set;",
"dropping as a data gap. NREGS reached universal coverage by 2008,",
"so this should NOT be a never-treated group -- confirm this is",
"really a data gap before trusting the plot."),
n_na, length(cohort_raw)))
cohort_map <- setNames(cohort_raw, first_row$sno)
df <- df[!is.na(cohort_map[as.character(sno)])]
g  <- as.integer(cohort_map[as.character(df$sno)])
data.table(unit = df$sno, time = as.integer(df$year),
Y = df$std_lt, D = as.integer(df$year >= g))
}
prep_castle_bacon <- function() {
df <- as.data.table(did2s::castle)
data.table(unit = df$state, time = as.integer(df$year),
Y = df$l_homicide, D = as.integer(df$post))
}
# -----------------------------------------------------------------------
# diagnostics -- flags issues rather than silently absorbing them
# -----------------------------------------------------------------------
check_panel <- function(dt, label) {
tab <- table(dt$unit)
if (length(unique(tab)) > 1L)
warning(sprintf("[%s] unbalanced panel: unit-period counts range %d-%d",
label, min(tab), max(tab)))
sw  <- dt[order(time), .(n_up = sum(diff(D) == 1L), n_down = sum(diff(D) == -1L)),
by = unit]
bad <- sw[n_up > 1L | n_down > 0L]
if (nrow(bad) > 0L)
warning(sprintf(
"[%s] %d unit(s) have non-absorbing D (re-treated or revert to untreated): %s",
label, nrow(bad), paste(head(bad$unit, 6), collapse = ", ")))
invisible(NULL)
}
# -----------------------------------------------------------------------
# corner-gradient background: light blue in the 4 corners fading to white
# at the centre. Built once as a small radial-alpha raster and reused
# across all plots (alpha, not a solid fill, so gridlines still show).
# -----------------------------------------------------------------------
make_corner_bg <- function(n = 120, rgb_corner = c(186, 214, 241), max_alpha = 130) {
s <- seq(-1, 1, length.out = n)
d <- sqrt(outer(s^2, s^2, "+"))
d <- d / max(d)
d <- d^2.2
alpha <- round(d * max_alpha)
matrix(rgb(rgb_corner[1], rgb_corner[2], rgb_corner[3], alpha = alpha, maxColorValue = 255),
nrow = n, ncol = n)
}
CORNER_BG <- make_corner_bg()
# -----------------------------------------------------------------------
# bacon() wrapper + plot. TYPE_* fixed globally so colours stay consistent
# across all four plots even though each shows a different subset of types.
# Traffic-light palette: greens = clean, orange/blood-red = forbidden.
# -----------------------------------------------------------------------
TYPE_MAP <- c(
"Treated vs Untreated"     = "Treated vs. Never-Treated",
"Earlier vs Later Treated" = "Earlier vs. Later-Treated",
"Later vs Earlier Treated" = "Later vs. Already-Treated",
"Later vs Always Treated"  = "Later vs. Always-Treated"
)
TYPE_LEVELS <- c("Treated vs. Never-Treated", "Earlier vs. Later-Treated",
"Later vs. Already-Treated", "Later vs. Always-Treated")
FORBIDDEN_TYPES <- c("Later vs. Already-Treated", "Later vs. Always-Treated")
TYPE_COLORS <- c(
"Treated vs. Never-Treated" = "#2E9E44",
"Earlier vs. Later-Treated" = "#A4C639",
"Later vs. Already-Treated" = "#F77F00",
"Later vs. Always-Treated"  = "#8B0000"
)
run_dataset_bacon <- function(dt, label, unit_noun = "units") {
check_panel(dt, label)
bc <- bacon(Y ~ D, data = as.data.frame(dt), id_var = "unit",
time_var = "time", quietly = TRUE)
setDT(bc)
bc[, type_clean := factor(TYPE_MAP[type], levels = TYPE_LEVELS)]
bc[, forbidden  := type_clean %in% FORBIDDEN_TYPES]
twfe      <- feols(Y ~ D | unit + time, data = dt, cluster = ~unit)
twfe_est  <- coef(twfe)[["D"]]
twfe_se   <- se(twfe)[["D"]]
bacon_avg <- weighted.mean(bc$estimate, bc$weight)
if (abs(twfe_est - bacon_avg) > 1e-4)
warning(sprintf(
paste("[%s] feols TWFE (%.5f) and bacon()'s weighted-average 2x2 (%.5f)",
"differ by %.2e -- these should match exactly (Goodman-Bacon",
"identity); check for an unbalanced panel or non-absorbing D."),
label, twfe_est, bacon_avg, abs(twfe_est - bacon_avg)))
pct_forbidden <- 100 * sum(bc$weight[bc$forbidden]) / sum(bc$weight)
n_obs  <- nrow(dt)
n_unit <- uniqueN(dt$unit)
size_rng <- range(bc$weight)
p <- ggplot(bc, aes(weight, estimate)) +
annotation_raster(CORNER_BG, xmin = -Inf, xmax = Inf, ymin = -Inf, ymax = Inf,
interpolate = TRUE) +
geom_hline(yintercept = 0, linewidth = 0.4, color = "grey55") +
geom_hline(yintercept = twfe_est, linetype = "22", linewidth = 1.0,
color = "grey15") +
geom_point(aes(fill = type_clean, size = weight), shape = 21,
color = "grey20", stroke = 0.5, alpha = 0.92) +
annotate("text", x = max(bc$weight) * 0.98, y = twfe_est,
label = sprintf("TWFE = %.4f", twfe_est), hjust = 1, vjust = -0.7,
size = 3.6, color = "grey10", fontface = "bold") +
scale_fill_manual(values = TYPE_COLORS, drop = TRUE, name = NULL) +
scale_size_continuous(range = c(3.5, 13), guide = "none") +
scale_x_continuous(labels = scales::percent_format(accuracy = 1)) +
guides(fill = guide_legend(override.aes = list(size = 6, stroke = 0.6))) +
labs(title = label, x = "2x2 weight", y = "2x2 DiD estimate") +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", size = 15, margin = margin(b = 10)),
axis.line  = element_line(color = "grey20", linewidth = 0.5),
axis.ticks = element_line(color = "grey20", linewidth = 0.4),
legend.position = "bottom",
legend.text     = element_text(size = 11.5),
legend.key.size = unit(1.2, "lines"),
panel.grid.minor = element_blank(),
panel.grid.major = element_line(linewidth = 0.25, color = "grey88"),
plot.margin = margin(12, 16, 10, 12)
)
list(table = bc, plot = p, twfe_est = twfe_est, twfe_se = twfe_se,
pct_forbidden = pct_forbidden, n_obs = n_obs, n_unit = n_unit, label = label)
}
# -----------------------------------------------------------------------
# run everything
# -----------------------------------------------------------------------
beck_A_dt    <- prep_beck_bacon(file.path(data_dir, "panel_A_beck_replication.csv"), "A")
beck_B_dt    <- prep_beck_bacon(file.path(data_dir, "panel_B_modern_did_eligible.csv"), "B")
cook_shah_dt <- prep_cook_shah_bacon(file.path(data_dir, "district_light_panel.dta"))
castle_dt    <- prep_castle_bacon()
res_beck_A    <- run_dataset_bacon(beck_A_dt,    "Beck et al. (2010): Panel A (full sample)",    "states")
res_beck_B    <- run_dataset_bacon(beck_B_dt,    "Beck et al. (2010): Panel B (reduced sample)", "states")
res_cook_shah <- run_dataset_bacon(cook_shah_dt, "Cook & Shah (2023): NREGS",                     "districts")
res_castle    <- run_dataset_bacon(castle_dt,    "Cheng & Hoekstra (2013): Castle Doctrine",      "states")
cat("\n================ GOODMAN-BACON SUMMARY ================\n")
summary_dt <- rbindlist(lapply(
list(res_beck_A, res_beck_B, res_cook_shah, res_castle),
function(r) data.table(dataset = r$label, N_obs = r$n_obs, N_units = r$n_unit,
TWFE = round(r$twfe_est, 4), SE = round(r$twfe_se, 4),
pct_forbidden = round(r$pct_forbidden, 1))
))
print(summary_dt)
cat("\nCompare N_units / pct_forbidden against Table 6 (Beck) and Table 8 (Castle).\n")
cat("Beck Panel B: applications.R's comment says 37 states after dropping\n")
cat("always-treated; the draft's Table 6/7 says 36. N_units above is computed\n")
cat("directly from panel_B_modern_did_eligible.csv, so it will settle which.\n")
# --- inspect each plot, then uncomment the ggsave lines you want to keep ---
print(res_beck_A$plot)
ggsave(file.path(out_dir, "bacon_beck_panelA.png"), res_beck_A$plot, width = 9, height = 6.2, dpi = 300, bg = "white")
ggsave(file.path(out_dir, "bacon_beck_panelA.pdf"), res_beck_A$plot, width = 9, height = 6.2)
print(res_beck_B$plot)
ggsave(file.path(out_dir, "bacon_beck_panelB.png"), res_beck_B$plot, width = 9, height = 6.2, dpi = 300, bg = "white")
ggsave(file.path(out_dir, "bacon_beck_panelB.pdf"), res_beck_B$plot, width = 9, height = 6.2)
print(res_cook_shah$plot)
ggsave(file.path(out_dir, "bacon_cookshah.png"), res_cook_shah$plot, width = 9, height = 6.2, dpi = 300, bg = "white")
ggsave(file.path(out_dir, "bacon_cookshah.pdf"), res_cook_shah$plot, width = 9, height = 6.2)
print(res_castle$plot)
ggsave(file.path(out_dir, "bacon_castle.png"), res_castle$plot, width = 9, height = 6.2, dpi = 300, bg = "white")
ggsave(file.path(out_dir, "bacon_castle.pdf"), res_castle$plot, width = 9, height = 6.2)
if (requireNamespace("patchwork", quietly = TRUE)) {
library(patchwork)
combined <- (res_beck_A$plot + res_beck_B$plot) /
(res_cook_shah$plot + res_castle$plot) +
plot_layout(guides = "collect") +
plot_annotation(title = "Goodman-Bacon decomposition across all four applications",
theme = theme(plot.title = element_text(face = "bold", size = 17))) &
theme(legend.position = "bottom")
print(combined)
ggsave(file.path(out_dir, "bacon_all_four_combined.png"), combined, width = 16, height = 11, dpi = 300, bg = "white")
ggsave(file.path(out_dir, "bacon_all_four_combined.pdf"), combined, width = 16, height = 11)
} else {
cat("\ninstall.packages(\"patchwork\") to also get a combined 2x2 figure.\n")
}
rm(list = ls())
# staggeredGMM -- Goodman-Bacon decomposition plots
# Beck et al. (2010) Panel A / Panel B, Cook & Shah (2023), Cheng & Hoekstra (2013)
#
# For each dataset: runs bacondecomp::bacon() on the (unit, time, Y, D) panel
# and plots weight vs. 2x2 DiD estimate, coloured by comparison type.
#
# Data prep mirrors prep_beck() / prep_cook_shah() / prep_castle() in
# staggeredGMM_applications.R, trimmed to (unit, time, Y, D): bacon() infers
# cohort timing from D directly, so the g / g_inf / g_cs machinery those
# functions build for the GMM/GLS estimators isn't needed here.
#
# CASTLE NOTE: did2s::castle's `post` and `time_til` columns disagree on
# exactly two cells (Alaska 2006, Arizona 2006) -- see prior discussion.
# D below uses `post` as given, matching the paper's TWFE of 0.0694.
#
# bacon() mechanics confirmed by testing (not assumed): it natively splits
# already-treated controls into "Later vs Earlier Treated" and, when a unit
# is treated in the sample's very first period, "Later vs Always Treated".
# With a genuine never-treated group present it also returns "Treated vs
# Untreated". Checked against synthetic panels shaped like each case.
#
# NOT verified end-to-end: I don't have your Beck/Cook-Shah files, so I
# can't reproduce Table 6's exact numbers here beyond the Castle check
# above. The printed console summary is your check against that table --
# see the note by Beck Panel B (37 states per applications.R's comment vs.
# 36 in the draft's Table 6/7).
