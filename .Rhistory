geom_hline(yintercept = 0, linewidth = 0.4, color = "grey55") +
geom_hline(yintercept = twfe_est, linetype = "22", linewidth = 1.0,
color = "grey15") +
geom_point(aes(fill = type_clean, size = weight), shape = 21,
color = "grey20", stroke = 0.5, alpha = 0.92) +
annotate("text", x = max(bc$weight) * 0.98, y = twfe_est,
label = sprintf("TWFE = %.4f", twfe_est), hjust = 1, vjust = -0.7,
size = 3.6, color = "grey10", fontface = "bold") +
scale_fill_manual(values = TYPE_COLORS, drop = TRUE, name = NULL) +
scale_size_continuous(range = c(3.5, 13), guide = "none") +
scale_x_continuous(labels = scales::percent_format(accuracy = 1)) +
guides(fill = guide_legend(override.aes = list(size = 6, stroke = 0.6))) +
labs(title = label, x = "2x2 weight", y = "2x2 DiD estimate") +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", size = 15, margin = margin(b = 10)),
axis.line  = element_line(color = "grey20", linewidth = 0.5),
axis.ticks = element_line(color = "grey20", linewidth = 0.4),
legend.position = "bottom",
legend.text     = element_text(size = 11.5),
legend.key.size = unit(1.2, "lines"),
panel.grid.minor = element_blank(),
panel.grid.major = element_line(linewidth = 0.25, color = "grey88"),
plot.margin = margin(12, 16, 10, 12)
)
list(table = bc, plot = p, twfe_est = twfe_est, twfe_se = twfe_se,
pct_forbidden = pct_forbidden, n_obs = n_obs, n_unit = n_unit, label = label)
}
